{
  "name": "express-openapi-helpers",
  "version": "1.0.2",
  "description": "OpenAPI typed express router and operation resolver for express-openapi-validator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "import": "./dist/openapi.js"
    }
  },
  "files": [
    "dist"
  ],
  "author": "Henrik Hall",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/henhal/express-openapi-helpers.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "express": "^4.18.1",
    "express-openapi-validator": "^5.6.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "express": "^4.18.1",
    "express-openapi-validator": "^5.6.2"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": false
    },
    "express-openapi-validator": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build"
  }
}
